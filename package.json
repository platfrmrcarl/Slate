{
  "name": "wordpresskiller",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@node-rs/argon2": "2",
    "@oslojs/crypto": "1",
    "@oslojs/encoding": "1",
    "drizzle-orm": "0.44",
    "next": "16.2.6",
    "pino": "9",
    "postgres": "3.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "3"
  },
  "devDependencies": {
    "@eslint/js": "9",
    "@tailwindcss/postcss": "4",
    "@testing-library/jest-dom": "6",
    "@testing-library/react": "16",
    "@types/node": "22.19.19",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "2",
    "autoprefixer": "10",
    "drizzle-kit": "0.30",
    "eslint": "9",
    "eslint-config-next": "16",
    "eslint-config-prettier": "9",
    "happy-dom": "15",
    "jsdom": "25",
    "pino-pretty": "11",
    "prettier": "3",
    "tailwindcss": "4",
    "tsx": "4",
    "typescript": "5.7.3",
    "typescript-eslint": "8",
    "vitest": "2"
  }
}
