# NODE_ENV is set by tooling (next, vitest). Do not set here.

# PostgreSQL connection string (required)
DATABASE_URL=postgres://wpk:wpk@localhost:5432/wpk

# Logger level (default: info)
LOG_LEVEL=info

# HTTP port (default: 3000 dev, 8080 Cloud Run)
PORT=3000

# 64 random hex chars (generate with: openssl rand -hex 32)
AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# Public origin of the app; HTTPS required in production
APP_URL=http://localhost:3000

# JWT secret for preview tokens (required, 32+ chars; openssl rand -hex 32)
PREVIEW_TOKEN_SECRET=replace-me-with-openssl-rand-hex-32

# Shared secret for internal job callers (Cloud Tasks → /api/jobs/*)
INTERNAL_JOB_SECRET=replace-me-with-openssl-rand-hex-32

# OAuth (optional — set both halves of any pair you enable)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Resend transactional email (optional — when absent, emails log to stdout)
# RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# --- Media (required) ---
# GCS bucket for media uploads (required; must be a valid GCS bucket name)
GCS_BUCKET_MEDIA=wpk-media-local
# Set only in local dev — points to fake-gcs-server
GCS_EMULATOR_HOST=http://localhost:4443
# Public/CDN base URL for served media (optional)
MEDIA_PUBLIC_URL=http://localhost:3000

# --- Reserved for later sub-plans ---
# ANTHROPIC_API_KEY=
# GCS_BUCKET_THEMES=
