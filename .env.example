# NODE_ENV is set by tooling (next, vitest). Do not set here.

# PostgreSQL connection string (required)
DATABASE_URL=postgres://wpk:wpk@localhost:5432/wpk

# Logger level (default: info)
LOG_LEVEL=info

# HTTP port (default: 3000 dev, 8080 Cloud Run)
PORT=3000

# 64 random hex chars (generate with: openssl rand -hex 32)
AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# Public origin of the app; HTTPS required in production
APP_URL=http://localhost:3000

# JWT secret for preview tokens (required, 32+ chars; openssl rand -hex 32)
PREVIEW_TOKEN_SECRET=replace-me-with-openssl-rand-hex-32

# Shared secret for internal job callers (Cloud Tasks → /api/jobs/*)
INTERNAL_JOB_SECRET=replace-me-with-openssl-rand-hex-32

# OAuth (optional — set both halves of any pair you enable)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Resend transactional email (optional — when absent, emails log to stdout)
# RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# --- Media (required) ---
# GCS bucket for media uploads (required; must be a valid GCS bucket name)
GCS_BUCKET_MEDIA=wpk-media-local
# Set only in local dev — points to fake-gcs-server
GCS_EMULATOR_HOST=http://localhost:4443
# Public/CDN base URL for served media (optional)
MEDIA_PUBLIC_URL=http://localhost:3000

# --- AI (Claude) ---
# Anthropic API key — when absent, every AI feature degrades to a typed
# "disabled" result (no crashes). Format: sk-ant-...
# ANTHROPIC_API_KEY=
# Monthly per-user token budget. Default 2_000_000. The chat endpoint and all
# AI server actions return 429 (or an inline error) when the user is over.
# AI_MONTHLY_TOKEN_BUDGET=2000000
# Model overrides per feature (defaults match the latest published Claude tier
# for cost / latency / quality). Change only to pin or downgrade.
# AI_MODEL_GENERATE_PAGE=claude-opus-4-7
# AI_MODEL_REWRITE=claude-haiku-4-5
# AI_MODEL_ALT_TEXT=claude-haiku-4-5
# AI_MODEL_SEO_META=claude-haiku-4-5
# AI_MODEL_TRANSLATE=claude-sonnet-4-6
# AI_MODEL_CHAT=claude-sonnet-4-6
# AI_MODEL_SPAM=claude-haiku-4-5

# --- Observability ---
# Set to "true" to boot the OpenTelemetry SDK (traces to Cloud Trace, metrics
# to Cloud Monitoring on a 60s cadence). Disabled in dev / test by default.
# OTEL_ENABLED=false
# Reported as service.version on traces / metrics. Cloud Build sets this to
# the short SHA; locally you can leave it unset (defaults to "0.0.0").
# SLATE_VERSION=

# --- Themes (optional) ---
# Separate GCS bucket for theme bundles. When unset, theme code is loaded
# only from compose-time (themes/<slug>/ in the repo).
# GCS_BUCKET_THEMES=

# Set to "1" only on the slate.dev marketing deployment. When set, "/" renders
# the marketing landing page; when unset (the self-host default), "/" continues
# to redirect to /<defaultLocale> and the CMS-driven home page wins.
SLATE_MARKETING_HOME=
