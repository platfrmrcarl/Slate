# Node environment is set automatically by the tooling:
#   pnpm dev -> development
#   pnpm build / pnpm start -> production
#   pnpm test -> test
# Do NOT set NODE_ENV in this file — sourcing the file into a shell that
# subsequently runs `pnpm build` would mix dev/prod React bundles.
# NODE_ENV=development

# PostgreSQL connection string (required)
DATABASE_URL=postgres://wpk:wpk@localhost:5432/wpk

# Logger level (default: info). Options: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# HTTP port (default: 3000 dev, 8080 Cloud Run)
PORT=3000

# --- Reserved for later sub-plans (do not set in foundation) ---
# AUTH_SECRET=
# ANTHROPIC_API_KEY=
# RESEND_API_KEY=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GCS_BUCKET_MEDIA=
# GCS_BUCKET_THEMES=
